{
  "expo": {
    "name": "expo-intents-example",
    "slug": "expo-intents-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.intents.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.intents.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "../app.plugin.js",
        {
          "defaultLocale": "en",
          "intents": [
            {
              "name": "getGreeting",
              "title": { "en": "Get Greeting", "uk": "Отримати привітання" },
              "description": "Returns a greeting for the saved user.",
              "phrases": {
                "en": ["Get greeting from ${applicationName}"],
                "uk": ["Привітання від ${applicationName}"]
              }
            },
            {
              "name": "echo",
              "title": "Echo Message",
              "description": "Repeats the message you pass in, optionally shouting.",
              "parameters": [
                { "name": "message", "type": "string", "title": "Message" },
                { "name": "loud", "type": "boolean", "title": "Shout" }
              ]
            },
            {
              "name": "createReminder",
              "title": "Create Reminder",
              "description": "Demonstrates enum, optional, default and date parameters.",
              "parameters": [
                { "name": "text", "type": "string", "title": "Text" },
                {
                  "name": "priority",
                  "type": "enum",
                  "title": "Priority",
                  "default": "medium",
                  "choices": ["low", { "value": "medium", "title": "Medium" }, "high"]
                },
                { "name": "due", "type": "date", "title": "Due", "optional": true }
              ]
            },
            {
              "name": "completeTask",
              "title": "Complete Task",
              "description": "Pick one of your tasks (entity picker backed by JS).",
              "parameters": [{ "name": "task", "type": "entity", "entity": "Task", "title": "Task" }]
            }
          ],
          "entities": [{ "name": "Task", "title": "Task", "searchable": true }]
        }
      ]
    ]
  }
}